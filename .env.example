# AUTO_ML_RESEARCH_AGENT Environment Configuration
# Copy this file to .env and fill in your values

# Required: Get from https://console.groq.com/
GROQ_API_KEY=key
GROQ_API_KEY2=key2
GROQ_API_KEY3=key3
GROQ_API_KEY4=key4
GROQ_API_KEY5=key5
# Optional: Override defaults
# GROQ_MODEL=llama-3.3-70b-versatile
# TEMPERATURE=0.3
# MAX_RETRIES=3
# PATIENCE=10
# TEST_SIZE=0.2
# RANDOM_STATE=42
# CV_THRESHOLD=500
# EXPERIMENT_DB_PATH=experiments.json
# MODEL_REGISTRY_DIR=models
# DOWNLOAD_TIMEOUT=30
# PLAYWRIGHT_AUTH_STATE_PATH=playwright_auth/kaggle_state.json
# PLAYWRIGHT_HEADLESS=False
# SUPPRESS_SKLEARN_WARNINGS=True
# Dataset auto-search is Playwright/browser-only in runtime flow.
