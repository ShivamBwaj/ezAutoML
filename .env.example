# AUTO_ML_RESEARCH_AGENT Environment Configuration
# Copy this file to .env and fill in your values

# Required: Get from https://console.groq.com/
GROQ_API_KEY=key

# Optional: Override defaults
# GROQ_MODEL=llama-3.1-8b-instant
# TEMPERATURE=0.3
# MAX_RETRIES=3
# PATIENCE=5
# TEST_SIZE=0.2
# RANDOM_STATE=42
# CV_THRESHOLD=500
# EXPERIMENT_DB_PATH=experiments.json
# MODEL_REGISTRY_DIR=models
# DOWNLOAD_TIMEOUT=30
# SUPPRESS_SKLEARN_WARNINGS=True
# ENABLE_KAGGLE_SEARCH=True   # Kaggle API search enabled by default (though results are often poor/limited)
# ENABLE_HUGGINGFACE_SEARCH=False  # HF datasets usually junk - keep disabled
